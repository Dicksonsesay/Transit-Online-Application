# PostgreSQL connection string (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# NextAuth (required for student login and dashboard)
# NEXTAUTH_URL must match the URL in your browser exactly.
NEXTAUTH_SECRET="generate-a-random-secret-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Google sign-in (optional — enables "Continue with Google" on register/login)
# 1. Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
# 2. Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
# Use real values from Google Cloud Console (Web OAuth client).
# Client ID must end with .apps.googleusercontent.com
# GOOGLE_CLIENT_ID="123456789-abc.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxxxxxx"
# Production (Vercel) — set to your live site, e.g. https://your-app.vercel.app
# NEXTAUTH_URL="https://your-app.vercel.app"
# Example when using another device on your network:
# NEXTAUTH_URL="http://192.168.208.41:3000"

# Database seed (optional — defaults shown)
SEED_ADMIN_EMAIL="admin@transitcollege.sl"
SEED_ADMIN_PASSWORD="Admin@12345"
SEED_ADMIN_NAME="System Administrator"
SEED_TEST_PIN="TC-TEST-001"

# Email notifications (Gmail SMTP) — students receive portal alerts at their registered email
# 1. Enable 2-Step Verification on the Gmail account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Paste the 16-character app password into SMTP_PASS (not your normal Gmail password)
# Set EMAIL_ENABLED=false to disable outbound email (in-app notifications still work)
EMAIL_ENABLED="true"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="admission.transit@gmail.com"
SMTP_PASS="your-16-char-gmail-app-password"
EMAIL_FROM="Transit College Admissions <admission.transit@gmail.com>"
EMAIL_REPLY_TO="admission.transit@gmail.com"
APP_NAME="Transit College Sierra Leone"
# Links in student emails use PORTAL_URL first, then NEXTAUTH_URL.
# On Vercel, if these are still localhost, the app uses VERCEL_URL automatically.
# Production — set both to your live URL:
# PORTAL_URL="https://your-app.vercel.app"
PORTAL_URL="http://localhost:3000"

# Student document & passport photo uploads (required on Vercel — local disk is read-only)
# 1. In Vercel: Project → Storage → Create Blob store (links BLOB_READ_WRITE_TOKEN automatically)
# 2. Redeploy after adding storage
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
